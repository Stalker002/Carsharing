<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="CarsharingMobile.Views.RegistrationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:vm="clr-namespace:CarsharingMobile.ViewModels"
    Title="Регистрация"
    x:DataType="vm:RegistrationViewModel"
    BackgroundColor="#F4F5F7"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Grid
            Grid.Row="0"
            Padding="15,20"
            ColumnDefinitions="Auto, *"
            HeightRequest="80">
            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                HeightRequest="24"
                HorizontalOptions="Start"
                Source="back_icon_dark.png"
                WidthRequest="24" />
            <Label
                Grid.Column="1"
                Margin="-24,0,0,0"
                FontAttributes="Bold"
                FontSize="20"
                HorizontalOptions="Center"
                Text="Создание аккаунта"
                TextColor="#112347"
                VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30" Spacing="25">

                <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="15">
                    <Label
                        FontAttributes="Bold"
                        FontSize="24"
                        Text="Введите номер телефона"
                        TextColor="#112347" />
                    <Label
                        FontSize="14"
                        Text="Мы отправим SMS с кодом подтверждения"
                        TextColor="#6E6E6E" />

                    <VerticalStackLayout Margin="0,10,0,0" Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="55"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                x:Name="PhoneEntry"
                                Margin="15,0"
                                FontSize="18"
                                Keyboard="Telephone"
                                MaxLength="13"
                                Placeholder="+375 XX XXX-XX-XX"
                                PlaceholderColor="#ACACAC"
                                ReturnCommand="{Binding SendSmsCommand}"
                                ReturnType="Go"
                                Text="{Binding PhoneNumber, Mode=TwoWay}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding PhoneNumberError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding PhoneNumberError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <Button
                        Margin="0,20,0,0"
                        BackgroundColor="#3296F8"
                        Command="{Binding SendSmsCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        Text="Получить код"
                        TextColor="White" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsStep2}" Spacing="15">
                    <Label
                        FontAttributes="Bold"
                        FontSize="24"
                        Text="Код из SMS"
                        TextColor="#112347" />
                    <Label
                        FontSize="14"
                        Text="{Binding PhoneNumber, StringFormat='Код отправлен на номер {0}'}"
                        TextColor="#6E6E6E" />

                    <VerticalStackLayout Margin="0,10,0,0" Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="55"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                x:Name="SmsCodeEntry"
                                Margin="15,0"
                                CharacterSpacing="10"
                                FontSize="24"
                                HorizontalTextAlignment="Center"
                                Keyboard="Numeric"
                                MaxLength="4"
                                Placeholder="0000"
                                PlaceholderColor="#ACACAC"
                                ReturnCommand="{Binding VerifySmsCommand}"
                                ReturnType="Go"
                                Text="{Binding SmsCode}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding SmsCodeError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding SmsCodeError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <Button
                        Margin="0,20,0,0"
                        BackgroundColor="#3296F8"
                        Command="{Binding VerifySmsCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        Text="Подтвердить"
                        TextColor="White" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsStep3}" Spacing="15">
                    <Label
                        FontAttributes="Bold"
                        FontSize="24"
                        Text="Личные данные"
                        TextColor="#112347" />
                    <Label
                        FontSize="14"
                        Text="Осталось совсем чуть-чуть"
                        TextColor="#6E6E6E" />

                    <VerticalStackLayout Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="50"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                x:Name="NameEntry"
                                Margin="15,0"
                                Completed="OnNameCompleted"
                                Placeholder="Имя *"
                                PlaceholderColor="#ACACAC"
                                ReturnType="Next"
                                Text="{Binding Name}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding NameError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding NameError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="50"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                x:Name="SurnameEntry"
                                Margin="15,0"
                                Completed="OnSurnameCompleted"
                                Placeholder="Фамилия *"
                                PlaceholderColor="#ACACAC"
                                ReturnType="Next"
                                Text="{Binding Surname}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding SurnameError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding SurnameError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="50"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                x:Name="EmailEntry"
                                Margin="15,0"
                                Completed="OnEmailCompleted"
                                Keyboard="Email"
                                Placeholder="Email *"
                                PlaceholderColor="#ACACAC"
                                ReturnType="Next"
                                Text="{Binding Email}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding EmailError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding EmailError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="50"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Grid ColumnDefinitions="*, 50">
                                <Entry
                                    x:Name="PasswordEntry"
                                    Grid.Column="0"
                                    Margin="15,0"
                                    IsPassword="{Binding IsPasswordHidden}"
                                    Placeholder="Придумайте пароль *"
                                    PlaceholderColor="#ACACAC"
                                    ReturnCommand="{Binding ContinueToLicenseStepCommand}"
                                    ReturnType="Go"
                                    Text="{Binding UserPassword}"
                                    TextColor="#1E1E1E" />
                                <ImageButton
                                    Grid.Column="1"
                                    Padding="6"
                                    BackgroundColor="Transparent"
                                    Command="{Binding TogglePasswordCommand}"
                                    Source="{Binding PasswordIcon}" />
                            </Grid>
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding UserPasswordError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding UserPasswordError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <Button
                        Margin="0,20,0,0"
                        BackgroundColor="#3296F8"
                        Command="{Binding ContinueToLicenseStepCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        Text="Продолжить"
                        TextColor="White" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsStep4}" Spacing="15">
                    <Label
                        FontAttributes="Bold"
                        FontSize="24"
                        Text="Водительские права"
                        TextColor="#112347" />
                    <Label
                        FontSize="14"
                        Text="Для завершения регистрации добавьте действующее водительское удостоверение."
                        TextColor="#6E6E6E" />

                    <VerticalStackLayout Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="50"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                Margin="15,0"
                                Placeholder="Номер водительских прав *"
                                PlaceholderColor="#ACACAC"
                                Text="{Binding DriverLicenseNumber}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding DriverLicenseNumberError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding DriverLicenseNumberError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="0">
                        <Border
                            BackgroundColor="White"
                            HeightRequest="50"
                            Stroke="#E1E1E1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1">
                            <Entry
                                Margin="15,0"
                                Placeholder="Категория прав, например B *"
                                PlaceholderColor="#ACACAC"
                                Text="{Binding DriverLicenseCategory}"
                                TextColor="#1E1E1E" />
                        </Border>
                        <Label
                            Margin="5,4,0,0"
                            FontSize="12"
                            Text="{Binding DriverLicenseCategoryError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding DriverLicenseCategoryError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label
                                FontSize="13"
                                Text="Дата выдачи"
                                TextColor="#6E6E6E" />
                            <Border
                                BackgroundColor="White"
                                HeightRequest="50"
                                Stroke="#E1E1E1"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="1">
                                <DatePicker
                                    Margin="12,0"
                                    Date="{Binding DriverLicenseIssueDate}"
                                    Format="dd.MM.yyyy"
                                    MaximumDate="{x:Static sys:DateTime.Today}"
                                    TextColor="#1E1E1E" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label
                                FontSize="13"
                                Text="Действует до"
                                TextColor="#6E6E6E" />
                            <Border
                                BackgroundColor="White"
                                HeightRequest="50"
                                Stroke="#E1E1E1"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="1">
                                <DatePicker
                                    Margin="12,0"
                                    Date="{Binding DriverLicenseExpiryDate}"
                                    Format="dd.MM.yyyy"
                                    MinimumDate="{Binding DriverLicenseIssueDate}"
                                    TextColor="#1E1E1E" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <Label
                        Margin="5,-6,0,0"
                        FontSize="12"
                        Text="{Binding DriverLicenseExpiryDateError}"
                        TextColor="#FF3333">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding DriverLicenseExpiryDateError}"
                                TargetType="Label"
                                Value="{x:Null}">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontSize="13"
                            Text="Фото или PDF водительского удостоверения *"
                            TextColor="#6E6E6E" />
                        <Button
                            BackgroundColor="#FFFFFF"
                            BorderColor="#3296F8"
                            BorderWidth="1"
                            Command="{Binding PickDriverLicenseFileCommand}"
                            CornerRadius="8"
                            HeightRequest="50"
                            Text="ВЫБРАТЬ ФАЙЛ"
                            TextColor="#3296F8" />
                        <Label
                            FontSize="13"
                            Text="{Binding DriverLicenseFileName, TargetNullValue='Файл не выбран'}"
                            TextColor="#112347" />
                        <Label
                            FontSize="12"
                            Text="{Binding DriverLicenseFileError}"
                            TextColor="#FF3333">
                            <Label.Triggers>
                                <DataTrigger
                                    Binding="{Binding DriverLicenseFileError}"
                                    TargetType="Label"
                                    Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <Button
                        Margin="0,20,0,0"
                        BackgroundColor="#3296F8"
                        Command="{Binding CompleteRegistrationCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        Text="Завершить регистрацию"
                        TextColor="White" />
                </VerticalStackLayout>

                <ActivityIndicator
                    Margin="0,10"
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#3296F8" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
