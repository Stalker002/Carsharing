<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarsharingMobile.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:sensors="clr-namespace:Microsoft.Maui.Devices.Sensors;assembly=Microsoft.Maui.Essentials"
    xmlns:vm="clr-namespace:CarsharingMobile.ViewModels"
    x:DataType="vm:MainViewModel"
    Shell.NavBarIsVisible="False">

    <Grid>
        <maps:Map x:Name="CarMap" IsShowingUser="True">
            <maps:Map.Pins>
                <maps:Pin Address="ул. Козлова" Label="VW Polo">
                    <maps:Pin.Location>
                        <sensors:Location>
                            <x:Arguments>
                                <x:Double>53.9006</x:Double>
                                <x:Double>27.5590</x:Double>
                            </x:Arguments>
                        </sensors:Location>
                    </maps:Pin.Location>
                </maps:Pin>
            </maps:Map.Pins>
        </maps:Map>

        <Grid Padding="20,40,20,40" InputTransparent="False">

            <Border
                BackgroundColor="White"
                HeightRequest="50"
                HorizontalOptions="Start"
                StrokeShape="RoundRectangle 25"
                StrokeThickness="0"
                VerticalOptions="Start"
                WidthRequest="50">
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.2"
                        Radius="5"
                        Offset="0,2" />
                </Border.Shadow>
                <ImageButton
                    Padding="12"
                    Command="{Binding OpenMenuCommand}"
                    Source="menu_icon.png" />
            </Border>

            <VerticalStackLayout
                HorizontalOptions="End"
                Spacing="15"
                VerticalOptions="Center">
                <Border
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 25"
                    StrokeThickness="0"
                    WidthRequest="50">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.2"
                            Radius="5"
                            Offset="0,2" />
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <Button
                            Padding="0,0,0,0"
                            BackgroundColor="Transparent"
                            Clicked="OnZoomInClicked"
                            FontSize="24"
                            HeightRequest="50"
                            Text="+"
                            TextColor="#112347" />
                        <BoxView
                            Margin="10,0"
                            HeightRequest="1"
                            Color="#E1E1E1" />
                        <Button
                            Padding="0,0,0,10"
                            BackgroundColor="Transparent"
                            Clicked="OnZoomOutClicked"
                            FontSize="24"
                            HeightRequest="50"
                            Text="-"
                            TextColor="#112347" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    BackgroundColor="White"
                    HeightRequest="50"
                    StrokeShape="RoundRectangle 25"
                    StrokeThickness="0"
                    WidthRequest="50">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.2"
                            Radius="5"
                            Offset="0,2" />
                    </Border.Shadow>
                    <ImageButton
                        Padding="12"
                        Clicked="OnMyLocationClicked"
                        Source="my_location_icon.png" />
                </Border>

            </VerticalStackLayout>
        </Grid>

        <Border
            Padding="20,10,20,30"
            BackgroundColor="White"
            IsVisible="{Binding IsCardVisible}"
            StrokeShape="RoundRectangle 20,20,0,0"
            StrokeThickness="0"
            VerticalOptions="End">
            <Border.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.3"
                    Radius="10"
                    Offset="0,-2" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="15">
                <BoxView
                    Margin="0,0,0,10"
                    CornerRadius="2"
                    HeightRequest="4"
                    HorizontalOptions="Center"
                    WidthRequest="40"
                    Color="#E1E1E1">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseCardCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>
                <Grid ColumnDefinitions="120, *" ColumnSpacing="15">
                    <Image
                        Grid.Column="0"
                        Aspect="AspectFit"
                        HeightRequest="80"
                        Source="car_placeholder.png" />
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="VW Polo NEW AT"
                            TextColor="Black" />
                        <Label
                            FontSize="13"
                            Text="4 улица Берестянская"
                            TextColor="#999" />
                    </VerticalStackLayout>
                </Grid>
                <Button
                    Margin="0,10,0,0"
                    BackgroundColor="#76C54A"
                    Command="{Binding BookCarCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="55"
                    Text="ЗАБРОНИРОВАТЬ"
                    TextColor="White" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>