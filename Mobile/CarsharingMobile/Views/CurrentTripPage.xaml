<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="CarsharingMobile.Views.CurrentTripPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CarsharingMobile.ViewModels"
    x:DataType="vm:CurrentTripViewModel"
    BackgroundColor="{StaticResource BgLight}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid
            Grid.Row="0"
            Padding="15,20"
            ColumnDefinitions="Auto,*"
            HeightRequest="80">
            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                HeightRequest="24"
                HorizontalOptions="Start"
                Source="back_icon_dark.png"
                WidthRequest="24" />
            <Label
                Grid.Column="1"
                Margin="-24,0,0,0"
                FontAttributes="Bold"
                FontSize="20"
                HorizontalOptions="Center"
                Text="{Binding Title}"
                TextColor="{StaticResource TextDark}"
                VerticalOptions="Center" />
        </Grid>

        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">
            <Grid>
                <ScrollView>
                    <VerticalStackLayout Padding="16,0,16,24" Spacing="16">
                        <Border
                            Padding="18"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="1">
                            <VerticalStackLayout Spacing="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="22"
                                        Text="{Binding CarTitle}"
                                        TextColor="{StaticResource TextDark}" />
                                    <Label
                                        FontSize="14"
                                        Text="{Binding TariffText}"
                                        TextColor="{StaticResource TextGray}" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                    <Border
                                        Grid.Column="0"
                                        Padding="12"
                                        BackgroundColor="#EEF4FF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontSize="12" Text="Старт" TextColor="{StaticResource TextGray}" />
                                            <Label FontAttributes="Bold" FontSize="14" Text="{Binding StartedAtText}" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border
                                        Grid.Column="1"
                                        Padding="12"
                                        BackgroundColor="#EEF9F1"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontSize="12" Text="Минуты" TextColor="{StaticResource TextGray}" />
                                            <Label FontAttributes="Bold" FontSize="14" Text="{Binding PricePerMinuteText}" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border
                                        Grid.Column="2"
                                        Padding="12"
                                        BackgroundColor="#FFF6EA"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontSize="12" Text="Километры" TextColor="{StaticResource TextGray}" />
                                            <Label FontAttributes="Bold" FontSize="14" Text="{Binding PricePerKmText}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <Border
                                    Padding="14"
                                    BackgroundColor="#F7F9FC"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14">
                                    <VerticalStackLayout Spacing="8">
                                        <Label FontAttributes="Bold" FontSize="16" Text="Текущее местоположение" />
                                        <Label FontSize="14" Text="{Binding CurrentLocationText}" TextColor="{StaticResource TextDark}" />
                                        <Label FontSize="12" Text="{Binding CoordinatesText}" TextColor="{StaticResource TextGray}" />
                                        <Label FontSize="12" Text="{Binding LastSyncText}" TextColor="{StaticResource Primary}" />
                                        <Label FontSize="12" Text="{Binding TrackingStatusText}" TextColor="{StaticResource TextGray}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border
                                    Padding="14"
                                    BackgroundColor="#FFF3F3"
                                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                                    Stroke="#F1C6C6"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1">
                                    <Label
                                        FontSize="14"
                                        Text="{Binding ErrorMessage}"
                                        TextColor="#A33A3A" />
                                </Border>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border
                                        Grid.Column="0"
                                        Padding="12"
                                        BackgroundColor="#F7F9FC"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontSize="12" Text="Сутки" TextColor="{StaticResource TextGray}" />
                                            <Label FontAttributes="Bold" FontSize="14" Text="{Binding PricePerDayText}" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding FinishTripCommand}"
                                        IsEnabled="{Binding HasActiveTrip}"
                                        Text="Завершить поездку" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>

                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    VerticalOptions="Center"
                    Color="{StaticResource Primary}" />

                <Grid
                    BackgroundColor="#66000000"
                    IsVisible="{Binding IsFinishing}">
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="12"
                        VerticalOptions="Center">
                        <ActivityIndicator
                            IsRunning="{Binding IsFinishing}"
                            IsVisible="{Binding IsFinishing}"
                            Color="White" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Завершаем поездку..."
                            TextColor="White" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </RefreshView>
    </Grid>
</ContentPage>
