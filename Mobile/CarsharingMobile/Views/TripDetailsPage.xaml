<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarsharingMobile.Views.TripDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CarsharingMobile.ViewModels"
    x:DataType="vm:TripDetailsViewModel"
    BackgroundColor="{StaticResource BgLight}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!--  HEADER  -->
        <Grid
            Grid.Row="0"
            Padding="15,20"
            ColumnDefinitions="Auto,*"
            HeightRequest="80">
            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                HeightRequest="24"
                HorizontalOptions="Start"
                Source="back_icon_dark.png"
                WidthRequest="24" />
            <Label
                Grid.Column="1"
                Margin="-24,0,0,0"
                FontAttributes="Bold"
                FontSize="20"
                HorizontalOptions="Center"
                Text="Детализация поездки"
                TextColor="{StaticResource TextDark}"
                VerticalOptions="Center" />
        </Grid>

        <!--  КОНТЕНТ  -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">
            <Grid>
                <ScrollView>
                    <VerticalStackLayout Padding="16,0,16,24" Spacing="16">

                        <!--  ОШИБКА  -->
                        <Border
                            Padding="16"
                            BackgroundColor="#FFF3F3"
                            IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                            Stroke="#F1C6C6"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                            <Label
                                FontSize="14"
                                Text="{Binding ErrorMessage}"
                                TextColor="#A33A3A" />
                        </Border>

                        <!--  КАРТОЧКА: МАШИНА  -->
                        <Border
                            Padding="16"
                            BackgroundColor="{StaticResource Surface}"
                            IsVisible="{Binding HasDetails}"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="1">
                            <Grid ColumnDefinitions="100,*" ColumnSpacing="16">

                                <Image
                                    Grid.Column="0"
                                    Aspect="AspectFit"
                                    HeightRequest="60"
                                    Source="{Binding Details.CarCard.ImageUrl, TargetNullValue='car_placeholder.png'}"
                                    VerticalOptions="Center" />

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="4"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="18"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding Details.CarCard.Title}"
                                        TextColor="{StaticResource TextDark}" />
                                    <Label
                                        FontSize="13"
                                        Text="{Binding Details.CarCard.Transmission}"
                                        TextColor="{StaticResource TextGray}" />
                                    <Border
                                        Margin="0,2,0,0"
                                        Padding="6,2"
                                        BackgroundColor="White"
                                        HorizontalOptions="Start"
                                        Stroke="#C8C8C8"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            Text="{Binding Details.CarCard.RegistrationNumber}"
                                            TextColor="Black" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!--  КАРТОЧКА: ЦЕНА И ПРОБЕГ  -->
                        <Border
                            Padding="18,14"
                            BackgroundColor="{StaticResource Surface}"
                            IsVisible="{Binding HasDetails}"
                            Stroke="{StaticResource BorderLight}"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="1">
                            <Grid
                                ColumnDefinitions="*,Auto"
                                ColumnSpacing="16"
                                RowDefinitions="Auto,Auto">
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    Text="{Binding Details.Overview.DistanceText}"
                                    TextColor="{StaticResource TextDark}" />
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="20"
                                    HorizontalTextAlignment="End"
                                    Text="{Binding Details.Overview.AmountText}"
                                    TextColor="{StaticResource TextDark}" />
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,4,0,0"
                                    FontSize="13"
                                    Text="{Binding Details.Overview.DurationText}"
                                    TextColor="{StaticResource TextGray}" />
                            </Grid>
                        </Border>

                        <!--  КАРТОЧКА: КРАТКАЯ СВОДКА  -->
                        <VerticalStackLayout IsVisible="{Binding HasDetails}" Spacing="10">
                            <Label
                                Margin="4,0,0,0"
                                FontAttributes="Bold"
                                FontSize="16"
                                Text="Краткая сводка"
                                TextColor="{StaticResource TextDark}" />

                            <Border
                                Padding="0"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource BorderLight}"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Details.SummaryRows}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TripSummaryRowUiModel">
                                            <VerticalStackLayout>
                                                <Grid
                                                    Padding="16,14"
                                                    ColumnDefinitions="3.5*, 6.5*"
                                                    ColumnSpacing="12">
                                                    <Label
                                                        Grid.Column="0"
                                                        FontSize="14"
                                                        Text="{Binding Title}"
                                                        TextColor="{StaticResource TextGray}"
                                                        VerticalOptions="Center" />
                                                    <Label
                                                        Grid.Column="1"
                                                        FontAttributes="Bold"
                                                        FontSize="14"
                                                        HorizontalTextAlignment="End"
                                                        LineBreakMode="WordWrap"
                                                        Text="{Binding Value}"
                                                        TextColor="{StaticResource TextDark}"
                                                        VerticalOptions="Center" />
                                                </Grid>
                                                <!--  Разделительная линия аккуратно лежит под контентом  -->
                                                <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding HasPayments}" Spacing="10">
                            <Label
                                Margin="4,0,0,0"
                                FontAttributes="Bold"
                                FontSize="16"
                                Text="Платежи"
                                TextColor="{StaticResource TextDark}" />

                            <Border
                                Padding="0"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource BorderLight}"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Details.Payments}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TripPaymentUiModel">
                                            <VerticalStackLayout>
                                                <Grid
                                                    Padding="16,14"
                                                    ColumnDefinitions="Auto, *"
                                                    ColumnSpacing="12">
                                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                                        <Label
                                                            FontAttributes="Bold"
                                                            FontSize="14"
                                                            Text="{Binding Title}"
                                                            TextColor="{StaticResource TextDark}" />
                                                        <Label
                                                            FontSize="12"
                                                            Text="{Binding DateText}"
                                                            TextColor="{StaticResource TextGray}" />
                                                        <Label
                                                            FontSize="12"
                                                            Text="{Binding MethodText}"
                                                            TextColor="{StaticResource TextGray}" />
                                                    </VerticalStackLayout>
                                                    <Label
                                                        Grid.Column="1"
                                                        FontAttributes="Bold"
                                                        FontSize="15"
                                                        HorizontalTextAlignment="End"
                                                        Text="{Binding AmountText}"
                                                        TextColor="{StaticResource TextDark}"
                                                        VerticalOptions="Center" />
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!--  ПУСТОЕ СОСТОЯНИЕ  -->
                        <VerticalStackLayout
                            Padding="20,40"
                            IsVisible="{Binding IsEmptyStateVisible}"
                            Spacing="8">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalTextAlignment="Center"
                                Text="Детали поездки недоступны"
                                TextColor="{StaticResource TextDark}" />
                            <Label
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Text="Попробуйте обновить экран позже."
                                TextColor="{StaticResource TextGray}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    VerticalOptions="Center"
                    Color="{StaticResource Primary}" />
            </Grid>
        </RefreshView>
    </Grid>
</ContentPage>