<?xml version="1.0" encoding="UTF-8"?>

<Shell
    x:Class="CarsharingMobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CarsharingMobile.Views"
    xmlns:vm="clr-namespace:CarsharingMobile.ViewModels"
    x:DataType="vm:AppShellViewModel"
    FlyoutBehavior="Flyout">
    <Shell.FlyoutContent>
        <Grid
            Padding="20,50,20,20"
            BackgroundColor="#112347"
            RowDefinitions="Auto, *, Auto">

            <VerticalStackLayout
                Grid.Row="0"
                Margin="0,0,0,30"
                Spacing="5">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                </VerticalStackLayout.GestureRecognizers>
                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding Name}"
                    TextColor="White" />
                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding Surname}"
                    TextColor="White" />
            </VerticalStackLayout>

            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="20">

                    <HorizontalStackLayout Spacing="15">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTipsClicked" />
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image
                            HeightRequest="24"
                            Source="info_icon.png"
                            VerticalOptions="Center"
                            WidthRequest="24" />
                        <Label
                            FontSize="16"
                            Text="ПОДСКАЗКИ"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTripsClicked" />
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image
                            HeightRequest="24"
                            Source="car_icon.png"
                            VerticalOptions="Center"
                            WidthRequest="24" />
                        <Label
                            FontSize="16"
                            Text="ПОЕЗДКИ"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <Image
                            HeightRequest="24"
                            Source="gift_icon.png"
                            VerticalOptions="Center"
                            WidthRequest="24" />
                        <Label
                            FontSize="16"
                            Text="ПРОМОКОДЫ"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <Image
                            HeightRequest="24"
                            Source="chat_icon.png"
                            VerticalOptions="Center"
                            WidthRequest="24" />
                        <Label
                            FontSize="16"
                            Text="ПОДДЕРЖКА"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <BoxView
                        Margin="0,5"
                        HeightRequest="1"
                        Color="#213868" />

                    <HorizontalStackLayout Spacing="15">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutClicked" />
                        </HorizontalStackLayout.GestureRecognizers>
                        <Image
                            HeightRequest="24"
                            Source="logout_icon.png"
                            VerticalOptions="Center"
                            WidthRequest="24" />
                        <Label
                            FontSize="16"
                            Text="ВЫЙТИ ИЗ АККАУНТА"
                            TextColor="#FF3333"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout
                Grid.Row="2"
                Margin="0,20,0,0"
                HorizontalOptions="Center"
                Spacing="5">
                <Label
                    FontAttributes="Italic"
                    FontSize="12"
                    HorizontalOptions="Center"
                    Text="СЛУЖБА ПОДДЕРЖКИ"
                    TextColor="#ACACAC" />
                <Label
                    FontAttributes="Bold"
                    FontSize="14"
                    HorizontalOptions="Center"
                    Text="+375 29 000-00-00"
                    TextColor="White" />
                <Label
                    Margin="0,10,0,0"
                    FontSize="10"
                    HorizontalOptions="Center"
                    Text="ВЕРСИЯ 1.0.0"
                    TextColor="#6E6E6E" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutContent>

    <ShellContent
        ContentTemplate="{DataTemplate views:LoginPage}"
        FlyoutItemIsVisible="False"
        Route="LoginPage" />
    <ShellContent
        ContentTemplate="{DataTemplate views:MainPage}"
        FlyoutItemIsVisible="False"
        Route="MainPage" />

</Shell>