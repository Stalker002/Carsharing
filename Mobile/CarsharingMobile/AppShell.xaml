<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CarsharingMobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CarsharingMobile.Views"
    BackgroundColor="#1E1E1E"
    Shell.FlyoutBehavior="Disabled"
    TabBarBackgroundColor="#1E1E1E"
    TabBarTitleColor="#3296F8"
    TabBarUnselectedColor="#6E6E6E">

    <ShellContent ContentTemplate="{DataTemplate views:LoginPage}" Route="LoginPage" />

    <TabBar Route="MainTabs">
        <Tab Title="Авто" Icon="car_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
        </Tab>

        <Tab Title="Поездка" Icon="trip_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:CurrentTripPage}" Route="CurrentTripPage" />
        </Tab>

        <Tab Title="Профиль" Icon="profile_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>