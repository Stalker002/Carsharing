{
  "ConnectionStrings": {
    "CarsharingDbContext": "Host=<set-via-env>;Port=5432;Database=Carsharing;Username=<set-via-env>;Password=<set-via-env>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Minio": {
    "ServiceURL": "http://minio:9000",
    "PublicURL": "https://storage.example.com",
    "BucketName": "carsharing-images"
  },
  "FileUpload": {
    "MaxCarImageBytes": 5242880,
    "MaxDocumentImageBytes": 10485760
  },
  "JwtOptions": {
    "SecretKey": "<set-via-env>",
    "ExpiresHours": 12
  },
  "AllowedHosts": "*"
}
